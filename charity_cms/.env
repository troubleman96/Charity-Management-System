# =============================================================================
# CharityOS — Environment Variables
# =============================================================================

# --- Django Core ---
SECRET_KEY=django-insecure-change-this-in-production-a1b2c3d4e5f6g7h8i9
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Database (PostgreSQL — used in production) ---
DB_NAME=charity_cms
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- Redis & Celery ---
REDIS_URL=redis://localhost:6379/0

# --- Email (Console backend used in development) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@charity.org
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=CharityOS <noreply@charity.org>

# --- Organization Settings ---
ORG_NAME=Orphan Support Group
LOW_FUNDS_THRESHOLD=100000.00

# --- Django Settings Module ---
DJANGO_SETTINGS_MODULE=config.settings.development
